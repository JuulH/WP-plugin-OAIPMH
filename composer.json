{
	"name" : "kennisnet/oaipmh",
	"description" : "OAIPMH for WordPress.",
	"keywords" : [
		"wordpress",
		"plugin",
		"oaipmh"
	],
	"license" : "LGPL-3.0+",
	"type" : "wordpress-plugin",
	"require" : {
		"php" : ">=7.4",
        "picturae/oai-pmh" : "0.5.20",
        "laminas/laminas-diactoros" : "*",
        "laminas/laminas-httphandlerrunner" : "*"
	},
	"autoload" : {
		"psr-4" : {
			"App\\" : "app/"
		}
	},
	"config" : {
		"preferred-install" : "dist",
		"allow-plugins": {
            "composer/installers": true
        }
	}
}